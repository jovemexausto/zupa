{
  "name": "zupa-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Zupa pnpm workspace",
  "scripts": {
    "build": "turbo run clean && turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check --write ."
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.26.2",
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@zupa/testing": "workspace:*",
    "turbo": "^2.8.12"
  }
}